#!/usr/bin/env bash
# breeze-status — statusline output based on breeze's own status system
# Only counts "open" notifications (not claimed/pending/snoozed/resolved)
set -euo pipefail

BREEZE_DIR="${BREEZE_DIR:-$HOME/.breeze}"
INBOX="$BREEZE_DIR/inbox.json"
STATUS_FILE="$BREEZE_DIR/status.json"
BELL_STATE="$BREEZE_DIR/.bell_state"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Pass through stdin
cat > /dev/null

# If no inbox file, show nothing
if [ ! -f "$INBOX" ]; then
  exit 0
fi

# Check staleness (>10 min = stale)
if [ "$(uname)" = "Darwin" ]; then
  FILE_AGE=$(( $(date +%s) - $(stat -f %m "$INBOX") ))
else
  FILE_AGE=$(( $(date +%s) - $(stat -c %Y "$INBOX") ))
fi

if [ "$FILE_AGE" -gt 600 ]; then
  echo "/breeze: stale (poller not running?)"
  exit 0
fi

# Initialize status.json if missing
[ -f "$STATUS_FILE" ] || echo '{}' > "$STATUS_FILE"

# Count open notifications: total in inbox minus those with non-open status
# This is the single source of truth — same file, same number, every terminal
CURRENT_POLL=$(jq -r '.last_poll' "$INBOX" 2>/dev/null || echo "")

SUMMARY=$(jq -r --slurpfile status "$STATUS_FILE" '
  [.notifications[] | select(
    ($status[0][.id].status // "open") == "open"
  )]
  | if length == 0 then ""
    else
      . as $open |
      ($open | length) as $total |
      ($open | group_by(.type)
      | map({type: .[0].type, count: length})
      | sort_by(-.count)
      | map(
          if .type == "PullRequest" then "\(.count) PRs"
          elif .type == "Issue" then "\(.count) issues"
          elif .type == "Discussion" then "\(.count) discussions"
          elif .type == "Release" then "\(.count) releases"
          elif .type == "SecurityAlert" then "\(.count) security"
          else "\(.count) \(.type)"
          end
        )
      | "/breeze: " + join(" · "))
    end
' "$INBOX" 2>/dev/null)

OPEN_COUNT=$(jq --slurpfile status "$STATUS_FILE" '
  [.notifications[] | select(($status[0][.id].status // "open") == "open")] | length
' "$INBOX" 2>/dev/null || echo "0")

# Bell logic: ring once per new poll that increased the open count
NEW_SUFFIX=""
if [ -f "$BELL_STATE" ]; then
  PREV_POLL=$(cut -d' ' -f1 "$BELL_STATE" 2>/dev/null || echo "")
  PREV_COUNT=$(cut -d' ' -f2 "$BELL_STATE" 2>/dev/null || echo "0")

  if [ "$CURRENT_POLL" != "$PREV_POLL" ] && [ "$OPEN_COUNT" -gt "$PREV_COUNT" ]; then
    NEW_DIFF=$(( OPEN_COUNT - PREV_COUNT ))
    NEW_SUFFIX=" (+$NEW_DIFF new)"
    printf '\a'
  fi
fi

echo "$CURRENT_POLL $OPEN_COUNT" > "$BELL_STATE"

if [ -n "$SUMMARY" ]; then
  echo "${SUMMARY}${NEW_SUFFIX}"
fi
