#!/usr/bin/env bash
# breeze-status — reads inbox.json and outputs a one-line statusline summary
# Rings terminal bell when a new poll brings more notifications
set -euo pipefail

BREEZE_DIR="${BREEZE_DIR:-$HOME/.breeze}"
INBOX="$BREEZE_DIR/inbox.json"
BELL_STATE="$BREEZE_DIR/.bell_state"

# Pass through stdin (Claude Code sends session JSON)
cat > /dev/null

# If no inbox file, show nothing
if [ ! -f "$INBOX" ]; then
  exit 0
fi

# Check staleness (>10 min = stale)
if [ "$(uname)" = "Darwin" ]; then
  FILE_AGE=$(( $(date +%s) - $(stat -f %m "$INBOX") ))
else
  FILE_AGE=$(( $(date +%s) - $(stat -c %Y "$INBOX") ))
fi

if [ "$FILE_AGE" -gt 600 ]; then
  echo "/breeze: stale (poller not running?)"
  exit 0
fi

# Read current state from inbox (single jq call)
CURRENT=$(jq -r '
  {
    count: (.notifications | length),
    poll: .last_poll
  } | "\(.count) \(.poll)"
' "$INBOX" 2>/dev/null) || exit 0

CURRENT_COUNT=$(echo "$CURRENT" | cut -d' ' -f1)
CURRENT_POLL=$(echo "$CURRENT" | cut -d' ' -f2)

# Bell logic: ring once per new poll that increased the count
# bell_state stores "last_poll_ts last_count"
NEW_SUFFIX=""
if [ -f "$BELL_STATE" ]; then
  PREV_POLL=$(cut -d' ' -f1 "$BELL_STATE" 2>/dev/null || echo "")
  PREV_COUNT=$(cut -d' ' -f2 "$BELL_STATE" 2>/dev/null || echo "0")

  if [ "$CURRENT_POLL" != "$PREV_POLL" ] && [ "$CURRENT_COUNT" -gt "$PREV_COUNT" ]; then
    NEW_DIFF=$(( CURRENT_COUNT - PREV_COUNT ))
    NEW_SUFFIX=" (+$NEW_DIFF new)"
    printf '\a'
  fi
fi

# Update bell state (all terminals read the same file, same answer)
echo "$CURRENT_POLL $CURRENT_COUNT" > "$BELL_STATE"

# Build summary
SUMMARY=$(jq -r '
  .notifications
  | if length == 0 then ""
    else
      group_by(.type)
      | map({type: .[0].type, count: length})
      | sort_by(-.count)
      | map(
          if .type == "PullRequest" then "\(.count) PRs"
          elif .type == "Issue" then "\(.count) issues"
          elif .type == "Discussion" then "\(.count) discussions"
          elif .type == "Release" then "\(.count) releases"
          elif .type == "SecurityAlert" then "\(.count) security"
          else "\(.count) \(.type)"
          end
        )
      | "/breeze: " + join(" · ")
    end
' "$INBOX" 2>/dev/null)

if [ -n "$SUMMARY" ]; then
  echo "${SUMMARY}${NEW_SUFFIX}"
fi
